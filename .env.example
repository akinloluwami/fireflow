# =============================================================================
# FireFlow Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/vibeflow

# -----------------------------------------------------------------------------
# Auth (Required)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Credentials Encryption (Required for storing integration credentials)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=

# GitHub OAuth (optional, for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional, for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Tambo AI (Required for workflow builder)
# -----------------------------------------------------------------------------
VITE_TAMBO_API_KEY=your-tambo-api-key

# -----------------------------------------------------------------------------
# Slack Integration (Required for Slack actions)
# -----------------------------------------------------------------------------
# Create a Slack app at https://api.slack.com/apps
# Enable OAuth & Permissions, add scopes: chat:write, channels:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:2000/api/integrations/slack/callback

# -----------------------------------------------------------------------------
# Discord Integration (Required for Discord actions)
# -----------------------------------------------------------------------------
# Create a Discord app at https://discord.com/developers/applications
# Enable OAuth2, add scopes: bot, guilds, messages.read
# Bot permissions: Send Messages, Read Message History
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:2000/api/integrations/discord/callback

# -----------------------------------------------------------------------------
# Email Integration (Required for email actions)
# -----------------------------------------------------------------------------
# Sign up at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Optional: App URL (for OAuth callbacks)
# -----------------------------------------------------------------------------
# Set this to your production URL when deployed
APP_URL=http://localhost:2000
